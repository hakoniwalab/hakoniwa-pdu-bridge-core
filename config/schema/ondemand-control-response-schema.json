{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hakoniwa-lab.net/schemas/hakoniwa-pdu-bridge-ondemand-control-response-1.0.0.schema.json",
  "title": "Hakoniwa PDU Bridge On-Demand Control Response",
  "type": "object",
  "additionalProperties": false,
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["ok", "error", "subscribed", "sessions", "connections", "pdus", "health"]
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": "string"
    },
    "code": {
      "type": "string",
      "enum": [
        "INVALID_REQUEST",
        "NOT_FOUND",
        "BUSY",
        "UNSUPPORTED",
        "PERMISSION_DENIED",
        "INTERNAL_ERROR"
      ]
    },
    "hako_error": {
      "type": "integer",
      "minimum": 0
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "sessions": {
      "type": "array",
      "items": { "$ref": "#/$defs/session" }
    },
    "connections": {
      "type": "array",
      "items": { "$ref": "#/$defs/connection" }
    },
    "connection_id": {
      "type": "string",
      "minLength": 1
    },
    "pdus": {
      "type": "array",
      "items": { "$ref": "#/$defs/pdu" }
    },
    "health": { "$ref": "#/$defs/health" }
  },
  "$defs": {
    "filter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["robot"],
      "properties": {
        "robot": {
          "type": "string",
          "minLength": 1
        },
        "channel_id": {
          "type": "integer",
          "minimum": 0
        },
        "pdu_name": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "anyOf": [
            { "required": ["channel_id"] },
            { "required": ["pdu_name"] }
          ]
        }
      ]
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["immediate", "throttle", "ticker"]
        },
        "interval_ms": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "connection_id", "filters", "policy", "state"],
      "properties": {
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "connection_id": {
          "type": "string",
          "minLength": 1
        },
        "filters": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/filter" }
        },
        "policy": { "$ref": "#/$defs/policy" },
        "state": {
          "type": "string",
          "enum": ["Created", "Active", "Draining", "Closed"]
        }
      }
    },
    "connection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["connection_id", "node_id", "active", "epoch", "epoch_validation"],
      "properties": {
        "connection_id": {
          "type": "string",
          "minLength": 1
        },
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "active": {
          "type": "boolean"
        },
        "epoch": {
          "type": "integer",
          "minimum": 0
        },
        "epoch_validation": {
          "type": "boolean"
        }
      }
    },
    "pdu": {
      "type": "object",
      "additionalProperties": false,
      "required": ["connection_id", "robot", "pdu_name"],
      "properties": {
        "connection_id": {
          "type": "string",
          "minLength": 1
        },
        "robot": {
          "type": "string",
          "minLength": 1
        },
        "pdu_name": {
          "type": "string",
          "minLength": 1
        },
        "channel_id": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "required": ["running", "uptime_usec", "last_error"],
      "properties": {
        "running": {
          "type": "boolean"
        },
        "uptime_usec": {
          "type": "integer",
          "minimum": 0
        },
        "last_error": {
          "type": "string"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "type": { "const": "error" } }
      },
      "then": {
        "required": ["code", "message"]
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "subscribed" } }
      },
      "then": {
        "required": ["session_id"]
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "sessions" } }
      },
      "then": {
        "required": ["sessions"]
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "connections" } }
      },
      "then": {
        "required": ["connections"]
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "pdus" } }
      },
      "then": {
        "required": ["connection_id", "pdus"]
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "health" } }
      },
      "then": {
        "required": ["health"]
      }
    }
  ]
}
